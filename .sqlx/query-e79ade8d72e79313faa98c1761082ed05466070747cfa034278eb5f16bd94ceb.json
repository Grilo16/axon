  "query": "\n            SELECT \n                id as \"id!\", \n                workspace_id as \"workspace_id!\", \n                name as \"name!\", \n                options as \"options!: Json<BundleOptions>\", \n                created_at as \"created_at!\", \n                updated_at as \"updated_at!\" \n            FROM bundles \n            WHERE workspace_id = $1\n            ORDER BY created_at DESC\n            LIMIT $2 OFFSET $3\n            ",
