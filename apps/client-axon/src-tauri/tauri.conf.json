{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "axon",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../client-axon/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run tauri:dev-ui",
    "beforeBuildCommand": "npm run tauri:build-ui"
  },
  "app": {
    "windows": [
      {
        "title": "Axon",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
        "icons/apple-touch-icon.png",
        "icons/favicon.ico",         
        "icons/web-app-manifest-192x192.png",
        "icons/favicon.svg",         
        "icons/web-app-manifest-512x512.png",
        "icons/favicon-96x96.png"
    ]
  },
  "plugins": {

}
}


